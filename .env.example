BOT_TOKEN=your_telegram_bot_token_here
# Admin ID lar (vergul bilan: 123456789,987654321). Qo'shimcha adminlar bot orqali qo'shiladi
ADMIN_IDS=123456789,987654321
DATABASE_URL=postgresql://user:password@localhost:5432/loadbot_db

# Lokal: service_account.json fayl yo'li. Railway: to'liq JSON ni shu yerga qo'ying
GOOGLE_SHEETS_CREDENTIALS_JSON=service_account.json
GOOGLE_SHEET_KEY=your_load_sheet_key_here
GOOGLE_EXPENSES_SHEET_KEY=your_expenses_sheet_key_here

# Load board: Company Driver PDF Rate (Gross) bilan solishtiriladigan ustun raqami (1=A, 12=L, ...)
# LOAD_BOARD_RATE_COL=12

